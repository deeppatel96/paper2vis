ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# ── Extraction LLM (concept identification from paper sections) ─────────────
# Fast/cheap model is fine here — it just reads text and outputs structured JSON
LLM_PROVIDER=ollama           # anthropic | openai | ollama
LLM_MODEL=gpt-5.1
LLM_MODEL_MINI=gpt-5.1-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434   # use 127.0.0.1 when running with --network=host

# ── Codegen LLM (Manim scene code generation) ───────────────────────────────
# A stronger model produces much better animations. Falls back to LLM_PROVIDER if unset.
CODEGEN_PROVIDER=anthropic    # anthropic | openai | ollama
CODEGEN_MODEL=claude-opus-4-5

# Examples:
#   All Ollama:        set LLM_PROVIDER=ollama, leave CODEGEN_PROVIDER unset
#   Split (recommended): LLM_PROVIDER=ollama, CODEGEN_PROVIDER=anthropic
#   All Anthropic:     LLM_PROVIDER=anthropic, leave CODEGEN_PROVIDER unset

# ── Auth & hosting (required for deployed version, optional for local dev) ───
# Clerk — https://clerk.com (create a free app, copy keys from dashboard)
CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase — https://supabase.com (create a free project, run supabase/schema.sql)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin secret — used to upgrade users to Pro via POST /api/admin/users/{id}/tier
ADMIN_SECRET=change_me_to_something_secret

# Invite code — share this with people you want to auto-upgrade to Pro
# They visit /invite?code=YOUR_CODE after signing up
INVITE_CODE_PRO=change_me_to_something_secret

# Frontend URL — the deployed Vercel URL (for CORS)
FRONTEND_URL=https://your-project.vercel.app

# DEV_TIER — tier used in local dev (auth disabled). Set to 'pro' to test Pro features.
DEV_TIER=pro
